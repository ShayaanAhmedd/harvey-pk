    "discover:pk:fbr-sros": "tsx scripts/extractors/discover-fbr-sros.ts",
    "extract:pakistan:all": "tsx scripts/extractors/orchestrator.ts",
    "extract:pakistan:resume": "tsx scripts/extractors/orchestrator.ts --resume",
    "extract:pakistan:smoke": "tsx scripts/extractors/orchestrator.ts --only discover-federal --resume",
    "backfill:pk:act-names": "tsx scripts/extractors/backfill-act-names.ts",
    "audit:completeness": "tsx scripts/extractors/audit-completeness.ts",
    "reingest:incomplete": "tsx scripts/extractors/reingest-incomplete.ts",
