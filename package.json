{
  "name": "harvey-pk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ingest-law": "ts-node --project scripts/tsconfig.json scripts/ingest-law.ts",
    "ingest-folder": "ts-node --project scripts/tsconfig.json scripts/ingest-folder.ts",
    "extract:uk": "tsx scripts/extractors/runner.ts --jurisdiction uk --limit 5",
    "extract:pk": "tsx scripts/extractors/runner.ts --jurisdiction pakistan --limit 5",
    "extract:all": "tsx scripts/extractors/runner.ts --jurisdiction all --limit 5",
    "extract:status": "tsx scripts/extractors/runner.ts --status",
