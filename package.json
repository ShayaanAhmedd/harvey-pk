    "framer-motion": "^11.18.2",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "nodemailer": "^6.10.1",
    "openai": "^6.23.0",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "parse": "^8.2.0",
    "pdf": "^0.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.0.379",
    "pdfkit": "^0.17.2",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tesseract.js": "^5.0.4",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.60.0",
