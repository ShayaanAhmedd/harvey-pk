    "reingest:partial": "tsx scripts/extractors/reingest-partial.ts",
    "reingest:partial:dryrun": "tsx scripts/extractors/reingest-partial.ts --dry-run",
    "backfill:sections": "tsx scripts/extractors/backfill-section-numbers.ts",
    "backfill:sections:dryrun": "tsx scripts/extractors/backfill-section-numbers.ts --dry-run",
    "reextract:ppc:test": "tsx scripts/extractors/reextract-pdfjs.ts",
    "insert:ppc:reextract": "tsx scripts/extractors/insert-reextracted-chunks.ts",
    "reextract:all": "tsx scripts/extractors/reextract-all.ts",
    "reextract:all:resume": "tsx scripts/extractors/reextract-all.ts",
    "discover:pk:lhc:test": "tsx scripts/extractors/discover-lhc-playwright.ts --max-pages 3 --out data/seeds/pakistan-lhc-test.csv",
    "discover:pk:lhc:full": "tsx scripts/extractors/discover-lhc-playwright.ts --out data/seeds/pakistan-lhc.csv",
    "discover:pk:lhc:resume": "tsx scripts/extractors/discover-lhc-playwright.ts --out data/seeds/pakistan-lhc.csv --resume true",
    "discover:pk:sindh:test": "tsx scripts/extractors/discover-sindh-playwright.ts --max-years 3 --out data/seeds/pakistan-sindh-test.csv",
    "discover:pk:sindh:full": "tsx scripts/extractors/discover-sindh-playwright.ts --out data/seeds/pakistan-sindh.csv",
    "discover:pk:sindh:resume": "tsx scripts/extractors/discover-sindh-playwright.ts --out data/seeds/pakistan-sindh.csv --resume true",
    "extract:csv": "tsx scripts/extractors/extract-from-csv.ts",
    "extract:pk:sindh:test": "tsx scripts/extractors/extract-from-csv.ts --seed data/seeds/pakistan-sindh.csv --tag sindh-statute --limit 10",
    "extract:pk:sindh:full": "tsx scripts/extractors/extract-from-csv.ts --seed data/seeds/pakistan-sindh.csv --tag sindh-statute"
